{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,

    "jsx": "react-jsx",
    "jsxImportSource": "@lynx-js/react",

    "lib": ["ES2023"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "noEmit": true,
